# ===== PRODUCTION (Render) =====
# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_random
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=https://mascertify.onrender.com

# Comma-separated emails → promoted to role "admin" on server start (login with same email)
ADMIN_EMAILS=you@example.com

# Public app URL (embed / badge links)
# APP_BASE_URL=https://mascertify.onrender.com

# Cloudinary (optional — org logo & course images via POST /api/media/upload)
# Use either CLOUDINARY_URL or the three variables below.
# CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=


# ===== DEVELOPMENT (Local) =====
# Uncomment below for local development
# PORT=5000
# NODE_ENV=development
# MONGO_URI=mongodb://localhost:27017/mascertify
# JWT_SECRET=dev_secret_key_not_for_production
# JWT_EXPIRE=7d
# CLIENT_URL=http://localhost:5173
# ADMIN_EMAILS=dev@localhost.test
